# Réseau
PORT=3001
HOST=127.0.0.1
# HOST=0.0.0.0   # pour exposer l'app sur le réseau local (autre Mac / téléphone)

# Données
DATABASE_PATH=/Users/your-user/path/to/La Fontaine/data/la-fontaine.sqlite
DATA_DIR=/Users/your-user/path/to/La Fontaine/data
SOURCE_INDEX_URL=https://fr.wikisource.org/wiki/Fables_de_La_Fontaine_(%C3%A9d._1874)

# Authentification (optionnelle) : si les deux sont définies, l'app exige un
# HTTP Basic (login/mot de passe). Laisser vide en local. /api/health reste public.
# BASIC_AUTH_USER=
# BASIC_AUTH_PASS=
