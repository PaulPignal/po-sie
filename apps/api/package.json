{
  "name": "@la-fontaine/api",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsup src/server.ts src/cli/import-fables.ts --format esm --platform node --out-dir dist --clean --splitting false",
    "start": "node --disable-warning=ExperimentalWarning --import tsx src/server.ts",
    "import:fables": "tsx src/cli/import-fables.ts",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@fastify/cors": "^11.0.1",
    "@fastify/static": "^8.1.1",
    "@la-fontaine/shared": "workspace:*",
    "cheerio": "^1.0.0",
    "fastify": "^5.2.1"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "tsup": "^8.4.0",
    "tsx": "^4.19.3",
    "vitest": "^3.0.8"
  }
}
